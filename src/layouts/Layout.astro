---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Rescripta Editores: Rescate y reedición de obras fundamentales para el patrimonio de Chile." } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Rescripta Editores</title>
		<meta name="description" content={description} />
		
		<!-- Google Fonts: Cormorant Garamond para el logo, Spectral para títulos e Inter para cuerpo -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&family=Spectral:ital,wght@0,400;0,500;0,700;1,400&family=Cormorant+Garamond:wght@300;500;700&display=swap" rel="stylesheet">
	</head>
	<body>
		<slot />
	</body>
</html>
